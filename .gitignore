# SignSpeak - Root .gitignore

# Python virtual environments & interpreters
venv/
.venv/
ENV/
env/
.Python
workspace.xml

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Testing & Reports
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/
**/comparison_reports/

# MediaPipe & Data (Landmark files)
*.npy
**/debug_input_frame.jpg
**/debug_processed_frame.jpg
**/image.png

# IDEs & System
.vscode/
.idea/
.DS_Store
*.swp
*.bak